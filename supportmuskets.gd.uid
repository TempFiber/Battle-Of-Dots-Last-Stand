extends CharacterBody2D

var hp = 100.0
var MAX_HP = 100.0
var demage = 0.3
var bassicdemage = 0.3
var rangeddemage = 1.4
var basicrangeddemage = 1.4
var aktualny_demage = 0.3
var speed = 16.0
var target_position = Vector2.ZERO
var moving = false
var team = "black"
var current_enemy = null
var current_enemyranged = []
var current_enemies = []
enum State { GATHERING, WAITING, ATTACKING }
var state = State.GATHERING
var losoweleczenie = 2
var leczony = false
var fighting = false
var rally_point = Vector2(900, 200)
var rally_timer_started = false
var current_texture: Texture2D = null
var new_texture: Texture2D = null
var pom_texture: Texture2D = null
var gotoenemy = true
var walczynablisko = false
var shooting = false
var ammo = 26
var kolejnaszansanalospodejsca = true
var max_ammo = 26
var kill_fadeout := false
var szarza = false
var started = false
var placable = false
var selected = false
var reorganization = false
var price = 150

var previous_position: Vector2
var czyskanowac = true
var chasing_time: float = 0.0
var max_chasing_time: float = randf_range(1.0, 4.0) 

@export var zadanehp = 0


var medale = {
	"bronz": {
		"plus_hp": 10,
		"plus_atak": 0.2,
		"plus_speed": 1,
		"aktywny": false
	},
	"srebro": {
		"plus_hp": 20,
		"plus_atak": 0.4,
		"plus_speed": 2,
		"aktywny": false
	},
	"zloto": {
		"plus_hp": 30,
		"plus_atak": 0.8,
		"plus_speed": 3,
		"aktywny": false
	}
}

@export var number = 0
@export var musketsnumber = 0
@export var medal_lvl = 0



@onready var attack_line = $Line2D
@onready var cooldowntimer = $cooldowntimer
@onready var attack_area = $AttackArea
@onready var sprite = $Sprite2D
@onready var podsw = $Sprite2D2
@onready var timer = $Timer
@onready var znaksprite = $znakmuszket
@onready var rangedtimer = $rangedattacktimer
@onready var ammobar = $ammobar
@onready var medalebar = $levelup
@onready var nav = $NavigationAgent2D


#txt

var textura100hp: Texture2D = load("res://wojskablack/Infantry/rozlamysupport/1inf.png")
var textura80hp: Texture2D = load("res://wojskablack/Infantry/rozlamysupport/2inf.png")
var textura70hp: Texture2D = load("res://wojskablack/Infantry/rozlamysupport/3inf.png")
var textura50hp: Texture2D = load("res://wojskablack/Infantry/rozlamysupport/4inf.png")


func _ready():

	starthealing()
	medalebar.max_value = 60.0
	updatetxture()
	updateammo()
	updatetxture()
	await get_tree().create_timer(randf_range(3, 4)).timeout
	var dummy = [
		preload("res://wojskablack/Infantry/rozlamysupport/1inf.png"),
		preload("res://wojskablack/Infantry/rozlamysupport/2inf.png"),
		preload("res://wojskablack/Infantry/rozlamysupport/3inf.png"),
		preload("res://wojskablack/Infantry/rozlamysupport/4inf.png"),

	]

	
	attack_area.connect("body_entered", Callable(self, "_on_attack_area_body_entered"))
	attack_area.connect("body_exited", Callable(self, "_on_attack_area_body_exited"))
	timer.connect("timeout", Callable(self, "_on_timer_timeout"))
	set_health_bar()
	$AIScanTimer.connect("timeout", Callable(self, "scan_for_enemies"))
	$RallyTimer.connect("timeout", Callable(self, "_on_rally_timer_timeout"))
	if team == "white":
		add_to_group("white_units")
	elif team == "black":
		add_to_group("black_units")

func _physics_process(delta):
	if started == false:
		startedcheck()
	if started == true:
		scan_for_enemies()
		if kill_fadeout:
			$hitbox.disabled = true
			modulate.a = max(modulate.a - delta * 4, 0.0)  # 0.5 = prędkość zanikania
			if modulate.a <= 0.01:
				queue_free()
		if not sprite.texture:
			print("Przywracam teksturę!")
			sprite.texture = textura100hp
		set_health_bar()

		if not leczony:
			leczenie()

		if is_enemy_nearby(250):
			$timerleczeniav2.stop()
		else:
			$timerleczeniav2.start()

		match state:
			State.GATHERING:
				move_to(rally_point)
				if global_position.distance_to(rally_point) < 10:
					state = State.WAITING
					if not rally_timer_started:
						start_rally_timer()
					velocity = Vector2.ZERO

			State.WAITING:
				velocity = Vector2.ZERO
				state = State.WAITING

			State.ATTACKING:
				if moving and gotoenemy == true:
					
					
					
					var next_position = nav.get_next_path_position()
					var direction = (next_position - global_position).normalized()
					var distance = global_position.distance_to(next_position)

					var current_agent_postion 	= global_position
					var next_path_postion = nav.get_next_path_position()
					var new_velocity = current_agent_postion.direction_to(next_path_postion) * speed
				
					if nav.avoidance_enabled:
						nav.set_velocity(new_velocity)
					else:
						
						_on_nav_velocity_computed(new_velocity)
					if nav.is_navigation_finished() or distance < speed * delta:
					
						moving = false
						velocity = Vector2.ZERO
					else:
						velocity = direction * speed
						move_and_slide()
					if nav.is_navigation_finished() or distance < 5.0:  # Mały margines błędu
						moving = false
						velocity = Vector2.ZERO


					
func _on_nav_velocity_computed(safe_velocity : Vector2):
	velocity = safe_velocity




func _on_attack_area_body_entered(body):
	if started == true:
		if body.has_method("get_team") and body.get_team() != team:
			current_enemies.append(body)
			walczynablisko = true
			if timer.is_stopped():
				$timerleczenia.stop()
				timer.start()
				fighting = true
				cooldowntimer.stop()
func _on_attack_area_body_exited(body):
	if started == true:
		if body.has_method("get_team") and body.get_team() != team:
			current_enemies.erase(body)
		if current_enemies.is_empty():
			starthealing()
			timer.stop()
			cooldowntimer.wait_time = 6.0
			cooldowntimer.start()
			$timerleczenia.stop()
			walczynablisko = false
			

func _on_timer_timeout():
	demage = demage + randf_range(0, 0.2)
	if current_enemies.size() > 0:
		var split_damage = demage / current_enemies.size()
		for enemy in current_enemies:
			if enemy and enemy.has_method("take_damage"):
				enemy.call("take_damage", split_damage)
	else:
		timer.stop()
	demage = aktualny_demage
func get_team():
	return team

func _input_event(_viewport, event, _shape_idx):
	if event is InputEventMouseButton and event.button_index == MOUSE_BUTTON_LEFT and event.pressed:
		print("HP:", hp)

func take_damage(amount):
	hp -= amount
	$timerleczenia.stop()
	$timerleczeniav2.stop()
	$demageparticles.emitting = true
	updatetxture()
	if hp <= 0:
		start_fade_out()

func set_health_bar():
	$ProgressBar.value = hp

func scan_for_enemies():
	if reorganization == true:
		return
		
	# Mechanika pościgu (1-4s) - zostawiamy bez zmian
	if current_enemy != null and is_instance_valid(current_enemy):
		var dist = global_position.distance_to(current_enemy.global_position)
		if dist <= 60:
			chasing_time = 0
			var offset_x = randf_range(-20, 20)
			var offset_y = randf_range(-20, 20)
			target_position = current_enemy.global_position + Vector2(offset_x, offset_y)
			return
		else:
			chasing_time += get_physics_process_delta_time()
			if chasing_time < max_chasing_time:
				var offset_x = randf_range(-20, 20)
				var offset_y = randf_range(-20, 20)
				target_position = current_enemy.global_position + Vector2(offset_x, offset_y)
				return
			else:
				current_enemy = null

	# NOWA LOGIKA WYBORU CELU ▼▼▼
	var enemy_group = "black_units" if team == "white" else "white_units"
	var potential_targets = []  # Tutaj przechowamy WSZYSTKIE odpowiednie cele
	
	# 1. Znajdź najbliższego wroga
	var closest_enemy = null
	var closest_dist = INF
	for unit in get_tree().get_nodes_in_group(enemy_group):
		if unit.has_method("get_team") and unit.get_team() != team:
			if "shartted" in unit:
				if not unit.shartted:
					var dist = global_position.distance_to(unit.global_position)
					if dist < closest_dist:
						closest_enemy = unit
						closest_dist = dist
			
	if closest_enemy == null:
		return
	
	# 2. Dodaj najbliższego do puli celów
	potential_targets.append(closest_enemy)
	
	# 3. Znajdź wszystkich wrogów w 200px od najbliższego i dodaj do puli
	for unit in get_tree().get_nodes_in_group(enemy_group):
		if unit != closest_enemy and unit.has_method("get_team") and unit.get_team() != team:
			var dist_to_closest = closest_enemy.global_position.distance_to(unit.global_position)
			if dist_to_closest <= 50:
				potential_targets.append(unit)
	
	# 4. LOSUJ cel z całej puli (zarówno najbliższy jak i jego sąsiedzi)
	if potential_targets.size() > 0:
		var final_target = potential_targets[randi() % potential_targets.size()]  # Prawdziwie losowy wybór
		
		# Ustaw cel
		var offset_x = randf_range(-20, 20)
		var offset_y = randf_range(-20, 20)
		target_position = final_target.global_position + Vector2(offset_x, offset_y)
		moving = true
		state = State.ATTACKING
		current_enemy = final_target
		chasing_time = 0
		max_chasing_time = randf_range(1.0, 4.0)
	

func start_rally_timer():
	$RallyTimer.start()
	rally_timer_started = true

func move_to(pos: Vector2):
	target_position = pos
	moving = true

func _on_rally_timer_timeout():
	rally_timer_started = false
	state = State.ATTACKING
	var enemy_group = "black_units" if team == "white" else "white_units"
	var closest_enemy = null
	var closest_dist = INF
	for unit in get_tree().get_nodes_in_group(enemy_group):
		if unit.has_method("get_team") and unit.get_team() != team:
			var dist = global_position.distance_to(unit.global_position)
			if dist < closest_dist:
				closest_enemy = unit
				closest_dist = dist
	if closest_enemy:
		# Dodaj losowe przesunięcie również tutaj
		# Zmieniaj te wartości (-40, 40) aby dostosować szerokość frontu
		var offset_x = randf_range(-20, 20)
		var offset_y = randf_range(-20, 20)
		target_position = closest_enemy.global_position + Vector2(offset_x, offset_y)
	else:
		target_position = Vector2(0, randf_range(100, 300))
	moving = true

func is_enemy_nearby(radius := 100.0) -> bool:
	var enemy_group = "black_units" if team == "white" else "white_units"
	for unit in get_tree().get_nodes_in_group(enemy_group):
		if unit.has_method("get_team") and unit.get_team() != team:
			if global_position.distance_to(unit.global_position) <= radius:
				return true
	return false
func leczenie():
	if leczony == false and hp < MAX_HP:
		$timerleczenia.wait_time = randf_range(10, 14)
		$timerleczenia.start()
		leczony = true
		if hp > MAX_HP:
			hp = MAX_HP


func szukanie():
	if current_enemy == null:
		scan_for_enemies()
func update_current_enemy():
	var enemy_group = "black_units" if team == "white" else "white_units"
	var bodies_in_area = attack_area.get_overlapping_bodies()
	var closest = null
	var closest_dist = INF

	for body in bodies_in_area:
		if body.has_method("get_team") and body.get_team() != team:
			var dist = global_position.distance_to(body.global_position)
			if dist < closest_dist:
				closest = body
				closest_dist = dist

	current_enemy = closest


func _on_cooldownleczenia_timeout() -> void:
	fighting = false


func updatetxture():

	if hp <= 100 and hp > 90:
		new_texture = textura100hp
		pom_texture = textura100hp
	elif hp <= 90 and hp > 70:
		new_texture = textura80hp
		pom_texture = textura80hp
	elif hp <= 70 and hp > 50:
		new_texture = textura70hp
		pom_texture = textura70hp
	elif hp <= 50 and hp > 30:
		new_texture = textura50hp
		pom_texture = textura50hp

	if new_texture != current_texture:
		sprite.texture = new_texture
		current_texture = new_texture


func _on_musketattackarea_body_entered(body: Node2D) -> void:
	if started == true:
		if walczynablisko == false:
			if body.has_method("get_team") and body.get_team() != team:

				losuj_gotoenemy()
				current_enemyranged.append(body)
			if rangedtimer.is_stopped():
				rangedtimer.wait_time = 1.5
				rangedtimer.start()
				shooting = true


func _on_musketattackarea_body_exited(body: Node2D) -> void:
	if started == true:
		if body.has_method("get_team") and body.get_team() != team:
			current_enemyranged.erase(body)
			if current_enemyranged.is_empty():
				rangedtimer.stop()
				shooting = false
				gotoenemy = true
				kolejnaszansanalospodejsca = true
				szarza = false
				$cooldownwejscaiwrencz.stop()
			
func fade_out_line(duration: float) -> void:
	var time_passed = 0.0
	while time_passed < duration:
		var alpha = lerp(1, 0, time_passed / duration)
		attack_line.modulate.a = alpha
		await get_tree().process_frame
		time_passed += get_process_delta_time()
	# Po zaniku:
	attack_line.visible = false
	attack_line.clear_points()
	attack_line.modulate = Color(1, 1, 1, 1) # reset alfa
	
func _on_rangedattacktimer_timeout() -> void:
	if started == true:
		current_enemies = current_enemies.filter(func(enemy):
			return enemy != null and enemy.is_inside_tree()
		)
		if current_enemyranged.is_empty():
			gotoenemy = true
		if walczynablisko == false:
			if ammo > 0 and current_enemyranged.size() > 0:
				rangeddemage += randf_range(0.5, 1.0)
				
				var random_index = randi() % current_enemyranged.size()
				var enemy = current_enemyranged[random_index]
				updatemedals()
				if medale["bronz"]["aktywny"]:
					rangeddemage += medale["bronz"]["plus_atak"]
				if medale["srebro"]["aktywny"]:
					rangeddemage += medale["srebro"]["plus_atak"]
				if medale["zloto"]["aktywny"]:
					rangeddemage += medale["zloto"]["plus_atak"]

				if enemy and enemy.has_method("take_damage"):
					enemy.call("take_damage", rangeddemage)
					ammo -= 1
					updateammo()
					updatemedals()
					
					$wystrzal.visible = true
					$wystrzal2.visible = true
					$wystrzal3.visible = true
					
					$pwystrzale.wait_time = 0.4
					$pwystrzale.start()
					
					rangedtimer.stop()
					
					# Rysuj linię
					attack_line.clear_points()
					attack_line.add_point(Vector2.ZERO)
					attack_line.add_point(to_local(enemy.global_position))
					attack_line.visible = true
					
					# Wywołaj zanikanie linii
					await fade_out_line(0.3)
					zadanehp += demage
					rangeddemage = basicrangeddemage
					if current_enemyranged.size() > 0:
						if rangedtimer.is_stopped():
							rangedtimer.start()
func losuj_gotoenemy():
	if ammo > 0 and szarza == false:
		gotoenemy = false
		var chance = 0.10 
		if kolejnaszansanalospodejsca == true:
			if randf() < chance:
				gotoenemy = true
			else:
				gotoenemy = false
				kolejnaszansanalospodejsca = false
				if $cooldownwejscaiwrencz.is_stopped():
					$cooldownwejscaiwrencz.wait_time = randf_range(10,18)
					$cooldownwejscaiwrencz.start()
	else:
		gotoenemy = true

func _on_cooldownwejscaiwrencz_timeout() -> void:
	szarza = true
	kolejnaszansanalospodejsca = true
	$cooldownwejscaiwrencz.stop()
	var chance = 0.2
	if randf() < chance:
		gotoenemy = true
	else:
		gotoenemy = false
func updateammo():
	ammobar.value = ammo
	ammobar.max_value = max_ammo

func _on_pwystrzale_timeout():
	if has_node("wystrzal"): $wystrzal.visible = false
	if has_node("wystrzal2"): $wystrzal2.visible = false
	if has_node("wystrzal3"): $wystrzal3.visible = false
func _on_enemyupdatetimer_timeout() -> void:
	nav.target_position = target_position
	$enemyupdatetimer.stop()
	update_current_enemy()
	updatetxture()
	updateammo()
	updatemedals()
	if szarza == true:
		gotoenemy = true
	if current_enemyranged.is_empty():
		gotoenemy = true
		$cooldownwejscaiwrencz.stop()
	if ammo < 1:
		$cooldownwejscaiwrencz.stop()
	$enemyupdatetimer.start()
func form_line_while_attacking():
	var group_name = team + "_units"
	var units = get_tree().get_nodes_in_group(group_name)

	var my_index = 0
	for i in range(units.size()):
		if units[i] == self:
			my_index = i
			break

	var spacing = 20
	var base_position = rally_point
	var line_position = base_position + Vector2(spacing * my_index, 0)

	target_position = line_position
	moving = true

	szukanie()
func updatemedals():
	medalebar.value = zadanehp

	# BRĄZ
	if zadanehp > 50.0 and not medale["bronz"]["aktywny"]:
		medalebar.max_value = 140.0
		$medale/medalbronz.visible = true
		medale["bronz"]["aktywny"] = true

	# SREBRO
	if zadanehp > 140.0 and not medale["srebro"]["aktywny"]:
		medalebar.max_value = 200.0
		$medale/medalsrebro.visible = true
		medale["srebro"]["aktywny"] = true

	# ZŁOTO
	if zadanehp > 200.0 and not medale["zloto"]["aktywny"]:
		medalebar.max_value = 200.0
		$medale/medalzloto.visible = true
		medale["zloto"]["aktywny"] = true
		
func start_fade_out():
	kill_fadeout = true
	
func starthealing():
	if hp < MAX_HP:
		$timerleczenia.wait_time = randf_range(4,12)
		$timerleczenia.start()
func _on_timerleczenia_timeout() -> void:
	if hp < MAX_HP:
		hp += randf_range(1, 3)
	if hp > MAX_HP:
		hp = MAX_HP
	updatetxture()
func startedcheck():
	if Pokzwyaniebordera.started == true:
		started = true

func get_price():
	
	if MAX_HP <= 0:
		return 0
	
	var health_percent = float(hp) / float(MAX_HP)
	return int(price * health_percent)
